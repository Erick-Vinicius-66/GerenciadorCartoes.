@model IEnumerable<GerenciadorCartoes.Models.Cartao>

@{
    ViewData["Title"] = "Meus Cartões";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>💳 Cartões Cadastrados (Demonstração)</h2>
        <a asp-action="Create" class="btn btn-primary">➕ Cadastrar Novo Cartão</a>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info text-center" role="alert">
                    Nenhum cartão cadastrado ainda. Clique em "Cadastrar Novo Cartão" para começar!
                </div>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100 border-secondary">
                        <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
                            <span class="fw-bold">@item.Bandeira</span>
                            <span class="badge bg-secondary">Fake Data</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-muted mb-3">@item.NumeroMascarado</h5>
                            <p class="card-text mb-1"><strong>Titular:</strong> @item.NomeTitular.ToUpper()</p>
                            <div class="d-flex justify-content-between text-muted small">
                                <span><strong>Validade:</strong> @item.DataValidade</span>
                                <span><strong>CVV:</strong> ***</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-around">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Excluir</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>